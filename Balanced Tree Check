class Solution {
  private:
    pair<bool,int> getAns(Node* root){
        if(root==NULL){
            pair<bool,int> p=make_pair(true,0);
            return p;
        }
        pair<bool,int> left=getAns(root->left);
        pair<bool,int> right=getAns(root->right);
        pair<bool,int> ans;
        ans.first=(left.first && right.first) && (abs(left.second-right.second)<=1)?true:false;
        ans.second=max(left.second,right.second)+1;
        return ans;
    }
  public:
    bool isBalanced(Node* root) {
        // code here
        pair<bool,int> ans=getAns(root);
        return ans.first;
    }
};
