// https://leetcode.com/contest/weekly-contest-495/problems/first-matching-character-from-both-ends/submissions/1962362010/

class Solution {
public:
    int firstMatchingIndex(string s) {
        int n=s.length();
        for(int i=0;i<=n-i-1;i++){
            if(s[i]==s[n-i-1]){
                return i;
            }
        }
        return -1;
    }
};
