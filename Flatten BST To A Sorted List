#include <bits/stdc++.h> 
/************************************************************

    Following is the Binary Tree node structure
    
    template <typename T>
    class TreeNode {
        public :
        T data;
        TreeNode<T> *left;
        TreeNode<T> *right;

        TreeNode(T data) {
            this -> data = data;
            left = NULL;
            right = NULL;
        }

        ~TreeNode() {
            if(left)
                delete left;
            if(right)
                delete right;
        }
    };

************************************************************/
void inorder(vector<int>& in,TreeNode<int>* root){
    if(root==NULL){
        return;
    }
    inorder(in,root->left);
    in.push_back(root->data);
    inorder(in,root->right);
}
TreeNode<int>* flatten(TreeNode<int>* root)
{
    // Write your code here
    vector<int> in;
    inorder(in,root);
    TreeNode<int>* new_root=new TreeNode<int>(in[0]);
    TreeNode<int>* main_root=new_root;
    int i=1;
    while(i<in.size()){
        TreeNode<int>* temp=new TreeNode<int>(in[i++]);
        new_root->left=NULL;
        new_root->right=temp;
        new_root=temp;
    }
    new_root->left=NULL;
    new_root->right=NULL;
    return main_root;
}
