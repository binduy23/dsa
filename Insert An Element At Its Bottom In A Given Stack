#include <bits/stdc++.h> 
stack<int> pushAtBottom(stack<int>& myStack, int x) 
{
    // Write your code here.
    if(myStack.size()==0){
        myStack.push(x);
        return myStack;
    }
    int val=myStack.top();
    myStack.pop();
    pushAtBottom(myStack,x);
    myStack.push(val);
    return myStack;
}
