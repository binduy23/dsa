#include<bits/stdc++.h>
int signum(int maxi,int mini){
	if(maxi>mini){
		return 1;
	}
	else if(maxi<mini){
		return -1;
	}
	else{
		return 0;
	}
}
void get_median(int element,priority_queue<int>& maxi,priority_queue<int,vector<int>,greater<int>>& mini,int& median){
	switch(signum(maxi.size(),mini.size())){
		case 0:if(element<median){
				maxi.push(element);
				median=maxi.top();
			}
			else{
				mini.push(element);
				median=mini.top();
			}
		break;
		case 1:if(element>median){
				mini.push(element);
				median=(mini.top()+maxi.top())/2;
			}
			else{
				mini.push(maxi.top());
				maxi.pop();
				maxi.push(element);
				median=(mini.top()+maxi.top())/2;
			}
		break;
		case -1:if(element<median){
				maxi.push(element);
				median=(mini.top()+maxi.top())/2;
			}
			else{
				maxi.push(mini.top());
				mini.pop();
				mini.push(element);
				median=(mini.top()+maxi.top())/2;
			}
		break;
	}
}

vector<int> findMedian(vector<int> &arr, int n){
	// Write your code here 
	vector<int> ans;
	priority_queue<int> maxi;
	priority_queue<int,vector<int>,greater<int>> mini;
	int median=-1;
	for(int i=0;i<n;i++){
		get_median(arr[i],maxi,mini,median);
		ans.push_back(median);
	}
	return ans;
}
