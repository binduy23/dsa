#include <bits/stdc++.h> 
int findMinimumCost(string str) {
  // Write your code here
  if(str.length()%2==1){
    return -1;
  }
  stack<char> temp;
  for(int i=0;i<str.length();i++){
    if(str[i]=='{'){
      temp.push('{');
    }
    else{
      if(!temp.empty() && temp.top()=='{'){
        temp.pop();
      }
      else{
        temp.push('}');
      }
    }
  }
  int count1=0;
  int count2=0;
  while(!temp.empty()){
    if(temp.top()=='{'){
      count1++;
    }
    else{
      count2++;
    }
    temp.pop();
  }
  int ans=((count1+1)/2)+((count2+1)/2);
  return ans;
}
