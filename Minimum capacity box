// https://leetcode.com/contest/weekly-contest-492/problems/minimum-capacity-box/submissions/1941340633/

class Solution {
public:
    int minimumIndex(vector<int>& capacity, int itemSize) {
        int min=INT_MAX;
        int index=-1;
        for(int i=0;i<capacity.size();i++){
            if(capacity[i]>=itemSize && capacity[i]<min){
                index=i;
                min=capacity[i];
            }
        }
        
        return index;
    }
};©leetcode
