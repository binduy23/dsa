#include <bits/stdc++.h> 
bool isPossible(vector < vector < int >> & arr, int n,vector < vector < int >> & visited,int i,int j){
    if(i>=0 && j>=0 && i<n && j<n && arr[i][j]==1 && visited[i][j]==1){
        return true;
    }
    return false;
}
void solve(vector < vector < int >> & arr, int n,vector < vector < int >>& visited,vector<string>& ans,int i,int j, string &s){
    if(i==n-1 && j==n-1){
        ans.push_back(s);
        return;
    }
    if(isPossible(arr,n,visited,i+1,j)){
        visited[i+1][j]=0;
        s.push_back('D');
        solve(arr,n,visited,ans,i+1,j,s);
        s.pop_back();
        visited[i+1][j]=1;
    }
    if(isPossible(arr,n,visited,i,j-1)){
        visited[i][j-1]=0;
        s.push_back('L');
        solve(arr,n,visited,ans,i,j-1,s);
        s.pop_back();
        visited[i][j-1]=1;
    }
    if(isPossible(arr,n,visited,i,j+1)){
        visited[i][j+1]=0;
        s.push_back('R');
        solve(arr,n,visited,ans,i,j+1,s);
        s.pop_back();
        visited[i][j+1]=1;
    }

    if(isPossible(arr,n,visited,i-1,j)){
        visited[i-1][j]=0;
        s.push_back('U');
        solve(arr,n,visited,ans,i-1,j,s);
        s.pop_back();
        visited[i-1][j]=1;
    }
}
vector < string > searchMaze(vector < vector < int >> & arr, int n) {
    // Write your code here.
    vector<string> ans;
    if(arr[0][0]==0){
        return ans;
    }
    vector < vector < int >> visited(n,vector<int>(n, 1));
    string s="";
    int i=0,j=0;
    visited[0][0]=0;
    solve(arr,n,visited,ans,i,j,s);
    return ans;
}
