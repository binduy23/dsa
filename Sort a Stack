#include <bits/stdc++.h> 
void sortedStack(stack<int> &myStack,int x){
    if(myStack.size()==0 || myStack.top()<=x){
        myStack.push(x);
        return;
    }
    int val=myStack.top();
    myStack.pop();
    sortedStack(myStack,x);
    sortedStack(myStack,val);
    return;
}
