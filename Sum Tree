// https://www.geeksforgeeks.org/problems/sum-tree/1

/*  Tree node
struct Node
{
    int data;
    Node* left, * right;
}; */

// Should return true if tree is Sum Tree, else false
class Solution {
  private:
    pair<bool,int> getAns(Node* root){
        if(root==NULL){
            pair<bool,int> p=make_pair(true,0);
            return p;
        }
        if(root->left==NULL && root->right==NULL){
            pair<bool,int> p=make_pair(true,root->data);
            return p;
        }
        pair<bool,int> l=getAns(root->left);
        pair<bool,int> r=getAns(root->right);
        pair<bool,int> ans;
        ans.first=(l.second+r.second==root->data) && l.first && r.first;
        ans.second=l.second+r.second+root->data;
        return ans;
    }
  public:
    bool isSumTree(Node* root) {
        // Your code here
        pair<bool,int> ans=getAns(root);
        return ans.first;
    }
};
