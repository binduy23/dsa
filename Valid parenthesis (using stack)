bool isValidParenthesis(string s)
{
    // Write your code here.
    stack<char> temp;
    for(int i=0;i<s.length();i++){
        if(s[i]=='{' || s[i]=='(' || s[i]=='['){
            temp.push(s[i]);
        }
        else{
            if(temp.empty()){
                return false;
            }
            else if(s[i]-temp.top()==2 || s[i]-temp.top()==1){
                temp.pop();
            }
            else{
                return false;
            }
        }
    }
    return true;
}
